{
  "name": "oc-review",
  "displayName": "OC Review — opencode change review",
  "description": "Review, navigate and roll back opencode's edits across nested git repos; inline diff marks and quick-ask about any selection.",
  "version": "0.10.0",
  "publisher": "aleygey",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/aleygey/opencode-review" },
  "engines": { "vscode": "^1.90.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        { "id": "ocReview.changes", "name": "OC Review", "icon": "media/icon.svg" }
      ]
    },
    "commands": [
      { "command": "ocReview.connect", "category": "OC Review", "title": "Connect to opencode Server" },
      { "command": "ocReview.checkpoint", "category": "OC Review", "title": "Checkpoint Now (New Baseline)", "icon": "$(history)" },
      { "command": "ocReview.refresh", "category": "OC Review", "title": "Refresh", "icon": "$(refresh)" },
      { "command": "ocReview.acceptAll", "category": "OC Review", "title": "Accept All (New Baseline)", "icon": "$(check-all)" },
      { "command": "ocReview.openDiff", "category": "OC Review", "title": "Diff", "icon": "$(diff)" },
      { "command": "ocReview.revertFile", "category": "OC Review", "title": "Revert File", "icon": "$(discard)" },
      { "command": "ocReview.revertHunk", "category": "OC Review", "title": "Revert Hunk", "icon": "$(discard)" },
      { "command": "ocReview.revertRepo", "category": "OC Review", "title": "Revert Repo" },
      { "command": "ocReview.revertAll", "category": "OC Review", "title": "Revert All to Baseline" },
      { "command": "ocReview.undoRevert", "category": "OC Review", "title": "Undo Last Revert" },
      { "command": "ocReview.redoRevert", "category": "OC Review", "title": "Redo Revert" },
      { "command": "ocReview.baselines", "category": "OC Review", "title": "Baselines…", "icon": "$(timeline-view-icon)" },
      { "command": "ocReview.clearAskThreads", "category": "OC Review", "title": "Clear Ask Threads" },
      { "command": "ocReview.renameBaseline", "category": "OC Review", "title": "Rename Baseline (Note)" },
      { "command": "ocReview.toggleViewMode", "category": "OC Review", "title": "Toggle Tree/List View" },
      { "command": "ocReview.markReviewed", "category": "OC Review", "title": "Toggle Reviewed" },
      { "command": "ocReview.nextChange", "category": "OC Review", "title": "Next Change" },
      { "command": "ocReview.prevChange", "category": "OC Review", "title": "Previous Change" },
      { "command": "ocReview.toggleInline", "category": "OC Review", "title": "Toggle Inline Marks" },
      { "command": "ocReview.quickAsk", "category": "OC Review", "title": "Ask opencode About Selection" },
      { "command": "ocReview.askSubmit", "title": "问 opencode" },
      { "command": "ocReview.adoptRepo", "category": "OC Review", "title": "Adopt New Repo into Baseline" },
      { "command": "ocReview.explainPath", "category": "OC Review", "title": "Explain Path" },
      { "command": "ocReview.diagnose", "category": "OC Review", "title": "Diagnose" }
    ],
    "menus": {
      "editor/context": [
        { "command": "ocReview.quickAsk", "when": "editorTextFocus", "group": "ocreview@1" },
        { "command": "ocReview.openDiff", "when": "resourcePath in ocReview.changedPaths", "group": "ocreview@2" }
      ],
      "explorer/context": [
        { "command": "ocReview.openDiff", "when": "resourcePath in ocReview.changedPaths", "group": "3_compare@1" },
        { "command": "ocReview.revertFile", "when": "resourcePath in ocReview.changedPaths", "group": "3_compare@2" }
      ],
      "view/title": [
        { "command": "ocReview.checkpoint", "when": "view == ocReview.changes", "group": "navigation@1" },
        { "command": "ocReview.refresh", "when": "view == ocReview.changes", "group": "navigation@2" },
        { "command": "ocReview.acceptAll", "when": "view == ocReview.changes", "group": "navigation@3" },
        { "command": "ocReview.baselines", "when": "view == ocReview.changes", "group": "1_more@1" },
        { "command": "ocReview.revertAll", "when": "view == ocReview.changes", "group": "1_more@2" },
        { "command": "ocReview.undoRevert", "when": "view == ocReview.changes", "group": "1_more@3" },
        { "command": "ocReview.redoRevert", "when": "view == ocReview.changes", "group": "1_more@4" },
        { "command": "ocReview.renameBaseline", "when": "view == ocReview.changes", "group": "1_more@5" },
        { "command": "ocReview.toggleViewMode", "when": "view == ocReview.changes", "group": "1_more@6" }
      ],
      "view/item/context": [
        { "command": "ocReview.openDiff", "when": "view == ocReview.changes && viewItem == file", "group": "inline@1" },
        { "command": "ocReview.revertFile", "when": "view == ocReview.changes && viewItem == file", "group": "inline@2" },
        { "command": "ocReview.revertFile", "when": "view == ocReview.changes && viewItem == file", "group": "1_mod@1" },
        { "command": "ocReview.markReviewed", "when": "view == ocReview.changes && viewItem == file", "group": "1_mod@2" },
        { "command": "ocReview.revertRepo", "when": "view == ocReview.changes && viewItem == repoDir", "group": "1_mod@1" }
      ],
      "comments/commentThread/context": [
        { "command": "ocReview.askSubmit", "when": "commentController == ocReviewAsk", "group": "inline" }
      ]
    },
    "keybindings": [
      { "command": "ocReview.nextChange", "key": "ctrl+alt+pagedown", "when": "editorTextFocus" },
      { "command": "ocReview.prevChange", "key": "ctrl+alt+pageup", "when": "editorTextFocus" },
      { "command": "ocReview.quickAsk", "key": "ctrl+alt+a", "when": "editorTextFocus" },
      { "command": "editor.action.submitComment", "key": "enter", "when": "commentEditorFocused && !suggestWidgetVisible" }
    ],
    "configuration": {
      "title": "OC Review",
      "properties": {
        "ocReview.serverUrl": {
          "type": "string",
          "default": "",
          "description": "opencode server base URL (e.g. http://127.0.0.1:4096). Empty = auto-discover (lock file, then port probe)."
        },
        "ocReview.serverPassword": {
          "type": "string",
          "default": "",
          "description": "Password if the server was started with OPENCODE_SERVER_PASSWORD (HTTP basic, user 'opencode')."
        },
        "ocReview.probePorts": {
          "type": "array",
          "items": { "type": "number" },
          "default": [4096],
          "description": "Ports probed on 127.0.0.1 during auto-discovery."
        },
        "ocReview.viewMode": {
          "type": "string",
          "enum": ["tree", "list"],
          "default": "tree",
          "description": "Changes view layout: tree = hierarchical folders (like SCM tree view); list = flat with directory shown next to the filename."
        },
        "ocReview.notifyAgent": {
          "type": "boolean",
          "default": true,
          "description": "After a revert/undo/redo, send a context-only note into the owning opencode session so the agent re-reads changed files (no model turn is triggered)."
        },
        "ocReview.codeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show one-click revert CodeLens above changed hunks in the editor."
        },
        "ocReview.excludeDirs": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Extra directory NAMES to skip when discovering repos and watching for changes (on top of the built-in .git/node_modules/build/dist/… list). Speeds up scanning on a huge workspace. WARNING: opencode edits inside an excluded dir won't be reviewable — only exclude generated/vendored dirs the agent never touches."
        },
        "ocReview.autoCheckpoint": {
          "type": "string",
          "enum": ["turn", "off"],
          "default": "turn",
          "description": "turn = automatically checkpoint all repos when an opencode turn starts (only if the previous review is clean)."
        },
        "ocReview.shadowDir": {
          "type": "string",
          "default": "",
          "description": "Directory for the shadow baseline stores. Empty = extension global storage."
        },
        "ocReview.strictAttribution": {
          "type": "boolean",
          "default": true,
          "description": "Treat changes with no observed agent write ('unverified') as possibly user-owned: reverting them requires an explicit confirmation. Turn off only if you never edit files yourself during a session."
        },
        "ocReview.inlineMarks": {
          "type": "boolean",
          "default": true,
          "description": "Show inline change decorations (added-line background, deletion anchors) in editors."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/pure.test.ts",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.1.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
